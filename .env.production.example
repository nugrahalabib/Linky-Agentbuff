# Copy to .env.production on the VPS and fill in real values.
# File should be mode 600, owned by the deploy user.

# Production app URL
NEXT_PUBLIC_APP_URL=https://linky.agentbuff.id

# 32+ char random secret (generate: openssl rand -base64 32)
AUTH_SECRET=

# Database — Postgres URL once async migration lands; until then SQLite on a volume.
# Example Postgres on VPS: postgres://linky_user:PASSWORD@postgres_container:5432/linky
DATABASE_URL=file:/data/linky.db

# Redis (optional — degraded mode is fine for single instance)
REDIS_URL=

# Feature flags / misc
DEFAULT_LOCALE=id
