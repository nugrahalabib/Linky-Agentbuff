{
  "name": "linky",
  "version": "0.1.0",
  "private": true,
  "description": "Linky — Open-source, free-forever URL shortener with custom branded QR, analytics, and link-in-bio.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack -p 1709",
    "build": "next build",
    "start": "next start -p 1709",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "postinstall": "tsx scripts/migrate.ts || echo 'Migrations deferred'",
    "test": "node scripts/run-tests.mjs",
    "test:watch": "tsx --test --watch src/lib/**/*.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-slot": "^1.1.3",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.6",
    "ioredis": "^5.10.1",
    "jose": "^6.1.0",
    "lucide-react": "^0.544.0",
    "nanoid": "^5.1.5",
    "next": "15.5.4",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "recharts": "^3.2.1",
    "tailwind-merge": "^3.3.1",
    "ua-parser-js": "^2.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7",
    "@types/ua-parser-js": "^0.7.39",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.25.1",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.24.0"
}
