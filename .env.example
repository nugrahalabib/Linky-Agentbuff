# App
# Untuk production (linky.agentbuff.id), set: https://linky.agentbuff.id
# Untuk dev lokal: http://localhost:1709
NEXT_PUBLIC_APP_URL=http://localhost:1709
NEXT_PUBLIC_APP_NAME=Linky

# Database (SQLite file untuk dev; swap ke Postgres URL untuk produksi)
DATABASE_URL=file:./linky.db

# Auth — generate string random minimal 32 karakter untuk produksi
# e.g. `openssl rand -base64 32`
AUTH_SECRET=dev-secret-change-me-in-production-please-use-strong-random-value

# Locale default
DEFAULT_LOCALE=id
